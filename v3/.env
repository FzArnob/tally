# Base URL of the Tally v3 PHP API, relative to the web server root.
# XAMPP default: the project sits at http://localhost/tally/ so the v3 API is at
# /tally/v3/backend/ (single-file front controller routed by .htaccess).
# Change this if you deploy the project under a different path.
VITE_API_BASE=/tally/v3/backend/
# VITE_API_BASE=/backend/

# Google OAuth 2.0 "Web application" client ID (public — safe to expose).
# Must match GOOGLE_CLIENT_ID in v3/backend/config.php. Sign-in is disabled
# until this is set. Restart `vite` after changing it.
VITE_GOOGLE_CLIENT_ID=